# 应用配置
APP_NAME=SRC脱敏标注数据管理系统
APP_VERSION=1.0.0
DEBUG=True

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=src_data

# LLM配置
# 只需配置这两个变量即可，其他使用默认值
# 默认值：LLM_PROVIDER=openai, LLM_MODEL=gpt-4o-mini
# 如果未设置，将从环境变量OPENAI_API_KEY和OPENAI_BASE_URL读取
LLM_API_KEY=your_api_key_here
LLM_API_BASE=https://api.openai.com/v1

# 脱敏配置
# 是否在脱敏输出中包含LLM的思考过程
# true: 显示思考过程（用于调试）
# false: 不显示思考过程（生产环境推荐）
SHOW_LLM_THINKING_PROCESS=False

# 文件存储配置
UPLOAD_DIR=./uploads
CONVERTED_DIR=./converted
MAX_FILE_SIZE=52428800

# 安全配置
SECRET_KEY=your_secret_key_change_in_production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# 服务器配置
HOST=0.0.0.0
PORT=8000
